# Lokal (SQLite) – kein Eintrag nötig, läuft automatisch
DATABASE_URL="file:./prisma/fpl-liga.db"

# Turso (Produktion auf Vercel) – von Turso Dashboard kopieren
TURSO_DATABASE_URL="libsql://your-db-name.turso.io"
TURSO_AUTH_TOKEN="your-auth-token"

# JWT Secret – beliebigen langen String eingeben
JWT_SECRET="dein-geheimes-passwort-mindestens-32-zeichen"
